# ============================================
# BITLIS SEHRIM - Environment Configuration
# ============================================
# Copy to .env and fill in your values
# Ports chosen to avoid conflicts with other VPS projects

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5433
DB_USER=bitlis_user
DB_PASSWORD=change_me_strong_password
DB_NAME=bitlis_sehrim
DATABASE_URL=postgresql://bitlis_user:change_me_strong_password@localhost:5433/bitlis_sehrim

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=change_me_redis_password

# Backend API
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# JWT
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Twilio (SMS OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# OpenWeatherMap
OPENWEATHER_API_KEY=

# Admin Panel
ADMIN_PORT=3002

# CORS
CORS_ORIGIN=http://localhost:3002,http://localhost:8081
