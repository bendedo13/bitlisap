generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  USER
  BUSINESS
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum ListingStatus {
  ACTIVE
  SOLD
  EXPIRED
  DELETED
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum TargetType {
  BUSINESS
  LISTING
  EVENT
}

enum AdStatus {
  PENDING
  ACTIVE
  PAUSED
  EXPIRED
  REJECTED
}

enum AdPlacement {
  HOME_BANNER
  NEWS_INLINE
  MARKET_TOP
  MAP_FEATURED
  SPLASH_SCREEN
  CATEGORY_SPONSOR
}

enum PartnershipType {
  TAXI
  MARKET
  RESTAURANT
  HOTEL
  CARGO
  PHARMACY
  SERVICE
}

enum SubscriptionPlan {
  FREE
  BASIC
  PREMIUM
  ENTERPRISE
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ─── User ───
model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  fullName     String    @map("full_name")
  phone        String?   @unique
  avatarUrl    String?   @map("avatar_url")
  district     String?
  userType     UserType  @default(USER) @map("user_type")
  cityPoints   Int       @default(0) @map("city_points")

  // Optional profile fields
  age          Int?
  occupation   String?
  gender       Gender?
  bio          String?

  // Business registration fields
  businessName String?   @map("business_name")
  taxNo        String?   @unique @map("tax_no")

  // Online status
  isOnline     Boolean   @default(false) @map("is_online")
  lastSeen     DateTime? @map("last_seen")

  // Subscription
  subscriptionPlan  SubscriptionPlan @default(FREE) @map("subscription_plan")
  subscriptionEnds  DateTime?        @map("subscription_ends")

  isVerified   Boolean   @default(false) @map("is_verified")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  businesses       Business[]
  listings         Listing[]
  reviews          Review[]
  notifications    Notification[]
  pointTransactions PointTransaction[]
  sentMessages     Message[]         @relation("SentMessages")
  conversations1   Conversation[]    @relation("User1Conversations")
  conversations2   Conversation[]    @relation("User2Conversations")
  advertisements   Advertisement[]
  partnerships     Partnership[]
  newsAuthored     News[]
  eventsOrganized  Event[]
  emergencyAlerts  EmergencyAlert[]

  @@map("users")
}

// ─── Business ───
model Business {
  id            String   @id @default(uuid())
  name          String
  description   String?
  category      String
  subcategory   String?
  district      String
  address       String?
  phone         String?
  website       String?
  latitude      Float?
  longitude     Float?
  averageRating Float    @default(0) @map("average_rating")
  reviewCount   Int      @default(0) @map("review_count")
  isVerified    Boolean  @default(false) @map("is_verified")
  isPremium     Boolean  @default(false) @map("is_premium")
  isActive      Boolean  @default(true) @map("is_active")
  logoUrl       String?  @map("logo_url")
  coverUrl      String?  @map("cover_url")
  photos        String[]
  workingHours  String?  @map("working_hours")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  ownerId   String     @map("owner_id")
  owner     User       @relation(fields: [ownerId], references: [id])
  reviews   Review[]
  campaigns Campaign[]

  @@map("businesses")
}

// ─── Listing ───
model Listing {
  id            String        @id @default(uuid())
  title         String
  description   String?
  price         Float?
  isNegotiable  Boolean       @default(false) @map("is_negotiable")
  category      String
  subcategory   String?
  district      String?
  images        String[]
  photos        String[]
  status        ListingStatus @default(ACTIVE)
  isActive      Boolean       @default(true) @map("is_active")
  isPremium     Boolean       @default(false) @map("is_premium")
  viewCount     Int           @default(0) @map("view_count")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  sellerId      String        @map("seller_id")
  seller        User          @relation(fields: [sellerId], references: [id])
  conversations Conversation[]

  @@map("listings")
}

// ─── News ───
model News {
  id          String   @id @default(uuid())
  title       String
  summary     String?
  content     String
  category    String?
  imageUrl    String?  @map("image_url")
  isBreaking  Boolean  @default(false) @map("is_breaking")
  isOfficial  Boolean  @default(false) @map("is_official")
  tags        String[]
  viewCount   Int      @default(0) @map("view_count")
  likeCount   Int      @default(0) @map("like_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  authorId    String?  @map("author_id")
  author      User?    @relation(fields: [authorId], references: [id])

  @@map("news")
}

// ─── Event ───
model Event {
  id            String      @id @default(uuid())
  title         String
  description   String?
  startsAt      DateTime    @map("starts_at")
  endsAt        DateTime?   @map("ends_at")
  location      String?
  category      String?
  imageUrl      String?     @map("image_url")
  maxAttendees  Int?        @map("max_attendees")
  attendeeCount Int         @default(0) @map("attendee_count")
  isFree        Boolean     @default(true) @map("is_free")
  ticketPrice   Float?      @map("ticket_price")
  latitude      Float?
  longitude     Float?
  status        EventStatus @default(UPCOMING)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  organizerId   String?     @map("organizer_id")
  organizer     User?       @relation(fields: [organizerId], references: [id])

  @@map("events")
}


// ─── Review ───
model Review {
  id         String     @id @default(uuid())
  rating     Int
  comment    String?
  targetType TargetType @map("target_type")
  targetId   String     @map("target_id")
  createdAt  DateTime   @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])
  business   Business? @relation(fields: [targetId], references: [id])

  @@map("reviews")
}

// ─── Conversation ───
model Conversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user1Id   String    @map("user1_id")
  user2Id   String    @map("user2_id")
  listingId String?   @map("listing_id")
  user1     User      @relation("User1Conversations", fields: [user1Id], references: [id])
  user2     User      @relation("User2Conversations", fields: [user2Id], references: [id])
  listing   Listing?  @relation(fields: [listingId], references: [id])
  messages  Message[]

  @@unique([user1Id, user2Id, listingId])
  @@map("conversations")
}

// ─── Message ───
model Message {
  id        String   @id @default(uuid())
  content   String
  type      String   @default("text") // text, image, voice, location, file
  fileUrl   String?  @map("file_url")
  isRead    Boolean  @default(false) @map("is_read")
  readAt    DateTime? @map("read_at")
  createdAt DateTime @default(now()) @map("created_at")

  senderId       String       @map("sender_id")
  conversationId String       @map("conversation_id")
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@map("messages")
}

// ─── Notification ───
model Notification {
  id        String   @id @default(uuid())
  title     String
  body      String
  type      String
  data      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  @@map("notifications")
}

// ─── PointTransaction ───
model PointTransaction {
  id          String   @id @default(uuid())
  points      Int
  reason      String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  @@map("point_transactions")
}

// ─── Advertisement (Reklam/Sponsorluk) ───
model Advertisement {
  id          String      @id @default(uuid())
  title       String
  description String?
  imageUrl    String?     @map("image_url")
  targetUrl   String?     @map("target_url")
  placement   AdPlacement
  status      AdStatus    @default(PENDING)

  // Pricing
  dailyBudget Float?      @map("daily_budget")
  totalBudget Float       @map("total_budget")
  costPerClick Float?     @map("cost_per_click")
  costPerView  Float?     @map("cost_per_view")

  // Stats
  impressions Int         @default(0)
  clicks      Int         @default(0)
  revenue     Float       @default(0)

  // Dates
  startDate   DateTime    @map("start_date")
  endDate     DateTime    @map("end_date")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  advertiserId String     @map("advertiser_id")
  advertiser   User       @relation(fields: [advertiserId], references: [id])

  @@map("advertisements")
}

// ─── Partnership (Anlaşmalı İşletmeler - Gelir Ortaklığı) ───
model Partnership {
  id              String          @id @default(uuid())
  businessName    String          @map("business_name")
  type            PartnershipType
  description     String?
  commissionRate  Float           @map("commission_rate") // yüzde komisyon
  fixedMonthlyFee Float?          @map("fixed_monthly_fee") // sabit aylık ücret
  isActive        Boolean         @default(true) @map("is_active")

  // Stats
  totalOrders     Int             @default(0) @map("total_orders")
  totalRevenue    Float           @default(0) @map("total_revenue")
  totalCommission Float           @default(0) @map("total_commission")

  contactPhone    String?         @map("contact_phone")
  contactEmail    String?         @map("contact_email")
  contractStart   DateTime        @map("contract_start")
  contractEnd     DateTime?       @map("contract_end")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  partnerId       String          @map("partner_id")
  partner         User            @relation(fields: [partnerId], references: [id])

  @@map("partnerships")
}

// ─── Campaign (Fırsatlar & Kampanyalar) ───
model Campaign {
  id          String   @id @default(uuid())
  title       String
  description String?
  discount    String?  // "50% indirim", "2 al 1 öde" vb.
  imageUrl    String?  @map("image_url")
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  isActive    Boolean  @default(true) @map("is_active")
  clickCount  Int      @default(0) @map("click_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  businessId  String   @map("business_id")
  business    Business @relation(fields: [businessId], references: [id])

  @@map("campaigns")
}

// ─── Taxi (Taksi Durakları) ───
model Taxi {
  id        String   @id @default(uuid())
  name      String
  district  String
  address   String?
  phones    String[]
  latitude  Float?
  longitude Float?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("taxis")
}

// ─── Pharmacy (Eczaneler & Nöbetçi) ───
model Pharmacy {
  id          String    @id @default(uuid())
  name        String
  district    String
  address     String?
  phone       String?
  latitude    Float?
  longitude   Float?
  isDutyToday Boolean   @default(false) @map("is_duty_today")
  dutyDate    DateTime? @map("duty_date")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("pharmacies")
}

// ─── EmergencyAlert (Acil Durum Uyarısı) ───
model EmergencyAlert {
  id          String        @id @default(uuid())
  title       String
  message     String
  severity    AlertSeverity @default(HIGH)
  isActive    Boolean       @default(true) @map("is_active")
  expiresAt   DateTime?     @map("expires_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  createdById String        @map("created_by_id")
  createdBy   User          @relation(fields: [createdById], references: [id])

  @@map("emergency_alerts")
}
