generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// KULLANICILAR
// ============================================
enum UserType {
  USER
  BUSINESS
  ADMIN
  MODERATOR
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  phone         String    @unique @db.VarChar(20)
  fullName      String?   @db.VarChar(100)
  email         String?   @db.VarChar(150)
  avatarUrl     String?
  neighborhood  String?   @db.VarChar(50)
  district      String?   @db.VarChar(50)
  userType      UserType  @default(USER)
  isVerified    Boolean   @default(false)
  cityPoints    Int       @default(0)
  fcmToken      String?
  createdAt     DateTime  @default(now())
  lastSeen      DateTime?

  businesses    Business[]
  listings      Listing[]
  news          News[]
  events        Event[]
  reviews       Review[]
  sentMessages  Message[]       @relation("sender")
  receivedMessages Message[]    @relation("receiver")
  notifications Notification[]
  pointTransactions PointTransaction[]

  @@map("users")
}

// ============================================
// ISLETMELER
// ============================================
model Business {
  id              String    @id @default(uuid()) @db.Uuid
  ownerId         String    @db.Uuid
  name            String    @db.VarChar(150)
  category        String?   @db.VarChar(50)
  subcategory     String?   @db.VarChar(50)
  description     String?
  address         String?
  district        String?   @db.VarChar(50)
  latitude        Decimal?  @db.Decimal(10, 7)
  longitude       Decimal?  @db.Decimal(10, 7)
  phone           String?   @db.VarChar(20)
  whatsapp        String?   @db.VarChar(20)
  website         String?   @db.VarChar(200)
  instagram       String?   @db.VarChar(100)
  workingHours    Json?
  photos          String[]
  rating          Decimal   @default(0) @db.Decimal(3, 2)
  reviewCount     Int       @default(0)
  isPremium       Boolean   @default(false)
  premiumExpiresAt DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())

  owner           User      @relation(fields: [ownerId], references: [id])
  reviews         Review[]

  @@map("businesses")
}

// ============================================
// ILANLAR
// ============================================
enum ListingStatus {
  ACTIVE
  SOLD
  DELETED
}

model Listing {
  id              String        @id @default(uuid()) @db.Uuid
  sellerId        String        @db.Uuid
  title           String        @db.VarChar(200)
  description     String?
  category        String?       @db.VarChar(50)
  subcategory     String?       @db.VarChar(50)
  price           Decimal?      @db.Decimal(12, 2)
  isNegotiable    Boolean       @default(true)
  photos          String[]
  district        String?       @db.VarChar(50)
  isPremium       Boolean       @default(false)
  premiumExpiresAt DateTime?
  status          ListingStatus @default(ACTIVE)
  viewCount       Int           @default(0)
  createdAt       DateTime      @default(now())
  expiresAt       DateTime      @default(dbgenerated("NOW() + INTERVAL '30 days'"))

  seller          User          @relation(fields: [sellerId], references: [id])
  conversations   Conversation[]
  reviews         Review[]

  @@map("listings")
}

// ============================================
// HABERLER
// ============================================
model News {
  id            String   @id @default(uuid()) @db.Uuid
  authorId      String   @db.Uuid
  title         String   @db.VarChar(300)
  content       String?
  summary       String?  @db.VarChar(500)
  category      String?  @db.VarChar(50)
  thumbnailUrl  String?
  sourceUrl     String?
  isBreaking    Boolean  @default(false)
  isOfficial    Boolean  @default(false)
  likeCount     Int      @default(0)
  viewCount     Int      @default(0)
  publishedAt   DateTime @default(now())

  author        User     @relation(fields: [authorId], references: [id])

  @@map("news")
}

// ============================================
// ETKINLIKLER
// ============================================
enum EventStatus {
  UPCOMING
  ONGOING
  ENDED
}

model Event {
  id            String      @id @default(uuid()) @db.Uuid
  organizerId   String      @db.Uuid
  title         String      @db.VarChar(200)
  description   String?
  location      String?
  latitude      Decimal?    @db.Decimal(10, 7)
  longitude     Decimal?    @db.Decimal(10, 7)
  startsAt      DateTime
  endsAt        DateTime?
  category      String?     @db.VarChar(50)
  isFree        Boolean     @default(true)
  ticketPrice   Decimal?    @db.Decimal(10, 2)
  maxAttendees  Int?
  attendeeCount Int         @default(0)
  coverImage    String?
  status        EventStatus @default(UPCOMING)

  organizer     User        @relation(fields: [organizerId], references: [id])

  @@map("events")
}

// ============================================
// YORUMLAR
// ============================================
enum TargetType {
  BUSINESS
  LISTING
}

model Review {
  id                String     @id @default(uuid()) @db.Uuid
  userId            String     @db.Uuid
  targetId          String     @db.Uuid
  targetType        TargetType
  rating            Int
  comment           String?
  photos            String[]
  isVerifiedPurchase Boolean   @default(false)
  createdAt         DateTime   @default(now())

  user              User       @relation(fields: [userId], references: [id])
  business          Business?  @relation(fields: [targetId], references: [id], map: "review_business_fk")
  listing           Listing?   @relation(fields: [targetId], references: [id], map: "review_listing_fk")

  @@map("reviews")
}

// ============================================
// MESAJLASMA
// ============================================
model Conversation {
  id            String    @id @default(uuid()) @db.Uuid
  listingId     String?   @db.Uuid
  participants  String[]
  createdAt     DateTime  @default(now())

  listing       Listing?  @relation(fields: [listingId], references: [id])
  messages      Message[]

  @@map("conversations")
}

model Message {
  id              String       @id @default(uuid()) @db.Uuid
  conversationId  String       @db.Uuid
  senderId        String       @db.Uuid
  receiverId      String       @db.Uuid
  content         String
  isRead          Boolean      @default(false)
  createdAt       DateTime     @default(now())

  conversation    Conversation @relation(fields: [conversationId], references: [id])
  sender          User         @relation("sender", fields: [senderId], references: [id])
  receiver        User         @relation("receiver", fields: [receiverId], references: [id])

  @@map("messages")
}

// ============================================
// BILDIRIMLER
// ============================================
model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(200)
  body      String?
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@map("notifications")
}

// ============================================
// PUAN SISTEMI
// ============================================
model PointTransaction {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  points      Int
  action      String   @db.VarChar(50)
  description String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])

  @@map("point_transactions")
}
